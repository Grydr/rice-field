export SHELL=$(which bash)
export USER=$(id -un)

export QT_QPA_PLATFORM=xcb
export XDG_RUNTIME_DIR=/run/user/1000
export VCPKG_TOOLCHAIN="$VCPKG_ROOT/scripts/buildsystems/vcpkg.cmake"

alias srcbash="source ~/.bashrc"
alias la="ls -a"
alias ll="ls -l"
alias lah="ls -lah"
alias cls="clear"

if [ -n "$BASH_VERSION" ]; then
    bash_config_path="$HOME/.config/bash"
    container_name=$CONTAINER_ID
    if [[ -n $container_name ]]; then
        if [[ $container_name == *"banyu"* ]]; then
            source ${bash_config_path}/bashrc.ros-banyu
        else
            source ${bash_config_path}/bashrc.base
        fi
        return 0
    fi

    source ${bash_config_path}/bashrc.base
fi
