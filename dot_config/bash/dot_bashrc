export SHELL=$(which bash)
export USER=$(id -un)

export XDG_RUNTIME_DIR=/run/user/1000
export VCPKG_TOOLCHAIN="$VCPKG_ROOT/scripts/buildsystems/vcpkg.cmake"

alias srcbash="source ~/.bash_profile"
alias ..="cd .."
alias la="ls -a"
alias ll="ls -l"
alias lah="ls -lah"
alias cls="clear"

if [ -n "$BASH_VERSION" ]; then
    bash_config_path="$HOME/.config/bash"
    if [[ -n $CONTAINER_ID ]]; then
        if [[ $CONTAINER_ID == *"banyu"* ]]; then
            source ${bash_config_path}/bashrc.ros-banyu
        else
            source ${bash_config_path}/bashrc.base
        fi
        return 0
    fi

    source ${bash_config_path}/bashrc.base
fi
source "/home/gryd/Dev/ardupilot_ws/ardupilot/Tools/completion/completion.bash"
